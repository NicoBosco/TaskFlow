{
  "name": "taskflow-api",
  "version": "1.0.0",
  "description": "TaskFlow REST API — Express.js + PostgreSQL",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc && node -e \"const fs=require('fs'),path=require('path');const src='src/db',dst='dist/db';fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).forEach(d=>{const s=path.join(src,d),dd=path.join(dst,d);fs.mkdirSync(dd,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(path.join(s,f),path.join(dd,f)));});\"",
    "start": "node dist/scripts/migrate.js && node dist/app.js",
    "pretest": "node -e \"const fs = require('fs'); if (!fs.existsSync('.env.test')) fs.copyFileSync('.env.test.example', '.env.test');\" && cross-env NODE_ENV=test ts-node src/scripts/migrate.ts",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watchAll --runInBand",
    "migrate": "ts-node src/scripts/migrate.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "reset": "ts-node src/scripts/reset.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.10.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.2"
  }
}
